# Example env file for local dev (profile=dev).
# Copy to .env.dev (gitignored) e preencha com credenciais reais do seu ambiente.
# Arranque:  powershell -File scripts/workspace/run-api-dev.ps1
# Health:    powershell -File scripts/workspace/smoke-api-health.ps1
# Contrato: powershell -File scripts/workspace/smoke-api-contract.ps1
# PostgreSQL gerenciado: use sslmode=require; nao inclua channel_binding no JDBC.
# Use scripts/workspace/run-api-dev.ps1 or ./run_local.sh so values with "$" and "&"
# are parsed safely. Avoid `export $(cat .env.dev.example | xargs)`.

# PostgreSQL JDBC URL (omit channel_binding; ensure sslmode=require).
# Derived from DSN: postgresql://<user>:<pass>@<host>/<db>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://<db-host>:5432/<db-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=<db-password>

# DataSource RAG/config-store (pgvector)
CONFIG_DATASOURCE_URL=jdbc:postgresql://<config-host>:5432/<config-db-name>?sslmode=require
CONFIG_DATASOURCE_USERNAME=<config-db-user>
CONFIG_DATASOURCE_PASSWORD=<config-db-password>

# Embeddings (RAG)
PRAXIS_AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=gpt-5-mini
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=text-embedding-3-large

# Optional tuning
DB_POOL_SIZE=5
SPRING_PROFILES_ACTIVE=dev

# App binding (dev)
# Bind to IPv6/IPv4 (allows ::1 and 127.0.0.1)
SERVER_ADDRESS=::
# PORT can be set to override default 8088 (optional)
# PORT=8088

# --- Seguranca (dev) ---
# Senha do admin (usado no /auth/login)
PRACTICE_TEMP_PASSWORD=<local-admin-password>
# JWT e sessao (para dev)
APP_JWT_SECRET=<local-jwt-secret-at-least-32-bytes>
# Segredo independente para ETags assinados de recursos versionados e actions com If-Match.
PRAXIS_RESOURCE_VERSION_ETAG_SECRET=<local-resource-version-etag-secret-at-least-32-bytes>
APP_JWT_EXP_MIN=60
APP_SESSION_COOKIE_NAME=SESSION
APP_SESSION_SECURE=false
APP_SESSION_SAMESITE=Lax

# CORS/origin: ajuste para a URL do Angular local (cookies e config authoring exigem origem explicita)
# O host local-first oficial do workspace UI usa 4003; 4200 fica como fallback Angular CLI.
CORS_ALLOWED_ORIGINS=http://localhost:4003,http://127.0.0.1:4003,http://localhost:4200,http://127.0.0.1:4200,https://praxisui-dev.web.app
APP_SECURITY_CONFIG_ORIGIN_RESTRICTION_ALLOWED_ORIGINS=http://localhost:4003,http://127.0.0.1:4003,http://localhost:4200,http://127.0.0.1:4200,https://praxisui-dev.web.app

# Abrir leitura para facilitar dev (UI sem login inicialmente)
APP_SECURITY_READ_OPEN=true
APP_SECURITY_CSRF_DISABLE=true
APP_SECURITY_WRITE_DISABLED=false
APP_SECURITY_SCHEMAS_AGGREGATOR_ENABLED=true

# AI authoring local/browser-real: em dev, aceita identidade por headers para
# simular tenant/user sem principal corporativo. Nao use esses defaults em prod.
PRAXIS_AI_SECURITY_CORPORATE_MODE=false
PRAXIS_AI_SECURITY_ALLOW_HEADER_IDENTITY_IN_LOCAL=true
PRAXIS_AI_SECURITY_LOCAL_DEFAULT_TENANT=desenv
PRAXIS_AI_SECURITY_LOCAL_DEFAULT_USER=demo
PRAXIS_AI_SECURITY_LOCAL_DEFAULT_ENVIRONMENT=local

# Quickstart e host de referencia: ativa planos ricos de composicao UI de exemplo.
PRAXIS_AI_AUTHORING_REFERENCE_UI_COMPOSITION_PROVIDER_ENABLED=true
