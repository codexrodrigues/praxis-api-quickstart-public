# Example env file for production (Render, profile=prod)

# Render: add the vars below in Dashboard > Environment > Environment Variables

# PostgreSQL JDBC URL (sslmode required for managed databases; channel_binding is not used by JDBC driver)
SPRING_DATASOURCE_URL=jdbc:postgresql://<db-host>:5432/<db-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=REPLACE_WITH_RENDER_SECRET

# DataSource RAG/config-store (pgvector)
CONFIG_DATASOURCE_URL=jdbc:postgresql://<config-host>:5432/<config-db-name>?sslmode=require
CONFIG_DATASOURCE_USERNAME=<config-db-user>
CONFIG_DATASOURCE_PASSWORD=REPLACE_WITH_RENDER_SECRET

# Embeddings (RAG)
PRAXIS_AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=gpt-5-mini
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=text-embedding-3-large

# Pool
DB_POOL_SIZE=3
DB_POOL_MIN_IDLE=0
CONFIG_DB_POOL_SIZE=2
CONFIG_DB_POOL_MIN_IDLE=0

########################################
# Perfis e Runtime
########################################
# Ativa o profile de producao
SPRING_PROFILES_ACTIVE=prod
# Java flags (container-aware e heap limitada)
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=60.0 -XX:InitialRAMPercentage=25.0 -XX:MaxMetaspaceSize=160m -Dfile.encoding=UTF-8

# Quickstart publicado continua sendo host de referencia para planos ricos de composicao UI.
PRAXIS_AI_AUTHORING_REFERENCE_UI_COMPOSITION_PROVIDER_ENABLED=true

########################################
# Seguranca (prod)
########################################
# Senha do admin (endpoint /auth/login)
PRACTICE_TEMP_PASSWORD=REPLACE_WITH_RENDER_SECRET

# JWT e sessao
APP_JWT_SECRET=REPLACE_WITH_RENDER_SECRET
# Use um segredo forte e independente do JWT para ETags de concorrencia otimista.
PRAXIS_RESOURCE_VERSION_ETAG_SECRET=REPLACE_WITH_INDEPENDENT_RENDER_SECRET
APP_JWT_EXP_MIN=60
APP_SESSION_COOKIE_NAME=PRAXIS_HEROES
APP_SESSION_SECURE=true
# Se a UI estiver em dominio diferente, use None (requer Secure=true)
APP_SESSION_SAMESITE=None

# CSRF: manter habilitado em producao
APP_SECURITY_CSRF_DISABLE=false

# Leitura publica: usar lista branca em prod (read-open=false)
APP_SECURITY_READ_OPEN=false
# Lista branca (patterns) para GET/HEAD publicos
APP_SECURITY_READ_OPEN_WHITELIST=/api/human-resources/**,/api/operations/**,/api/assets/**,/api/risk-intelligence/**,/api/demo/**,/api/*/*/schemas/**,/api/*/*/schema/**,/api/*/*/filters/**,/api/*/*/options/**,/api/*/*/filtered,/schemas/filtered

# Desabilitar escrita na API (demo): POST/PUT/PATCH/DELETE negados
APP_SECURITY_WRITE_DISABLED=true
APP_SECURITY_SCHEMAS_AGGREGATOR_ENABLED=true
# Permitir apenas as acoes em lote (POST /api/*/*/actions/**) para fins de demonstracao
APP_SECURITY_DEMO_ALLOW_BULK_ACTIONS=false

########################################
# CORS
########################################
# Defina a(s) origem(ns) da UI (nao use "*")
# Exemplo (Firebase Hosting):
# CORS_ALLOWED_ORIGINS=https://praxis-ui-4e602.web.app,https://praxis-ui-4e602.firebaseapp.com
CORS_ALLOWED_ORIGINS=https://praxis-ui-4e602.web.app
